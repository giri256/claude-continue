{
  "manifest_version": 3,
  "name": "Claude Continue",
  "version": "4.0.0",
  "description": "Smart auto-resume for Claude chats with custom prompts, image pasting, and inline notifications.",
  "permissions": ["storage", "unlimitedStorage", "alarms", "tabs"],
  "host_permissions": ["*://claude.ai/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Dashboard"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
