{
  "manifest_version": 3,
  "name": "Claude Continue",
  "version": "1.0.0",
  "description": "Automatically resumes Claude chats when your limit resets.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions":["*://claude.ai/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Continue Status"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts":[
    {
      "matches": ["*://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
